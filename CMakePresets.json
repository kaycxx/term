{
    "version": 6,
    "configurePresets": [
        {
            "name": "debug-linux",
            "hidden": true,
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
                "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
            }
        },
        {
            "name": "debug-windows",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "/fsanitize=address"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "generator": "Ninja",
            "inherits": [
                "debug-linux",
                "debug-windows"
            ],
            "binaryDir": "${sourceDir}/build/debug"
        },
        {
            "name": "release",
            "displayName": "Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "windows-cross-debug",
            "displayName": "Windows Cross Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-debug",
            "toolchainFile": "${sourceDir}/cmake/toolchains/mingw-w64-x86_64.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_SHARED_LIBS": "OFF",
                "CMAKE_EXE_LINKER_FLAGS": "-static -static-libgcc -static-libstdc++"
            }
        },
        {
            "name": "windows-cross-release",
            "displayName": "Windows Cross Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-release",
            "toolchainFile": "${sourceDir}/cmake/toolchains/mingw-w64-x86_64.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_SHARED_LIBS": "OFF",
                "CMAKE_EXE_LINKER_FLAGS": "-static -static-libgcc -static-libstdc++"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "windows-cross-debug",
            "configurePreset": "windows-cross-debug"
        },
        {
            "name": "windows-cross-release",
            "configurePreset": "windows-cross-release"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "release",
            "configurePreset": "release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
